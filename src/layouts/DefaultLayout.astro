---
// src/layouts/DefaultLayout.astro
// Standard layout shell: sticky top nav, main content area, footer.
// Visible by default; hidden when data-theme is "pixel" or "editorial".

interface Props {
  fullBleed?: boolean;
}

const { fullBleed = false } = Astro.props;

const path = Astro.url.pathname;
const navItems = [
  { href: "/work",  label: "Work"  },
  { href: "/lab",   label: "Lab"   },
  { href: "/about", label: "About" },
];
---

<div id="shell-default" aria-hidden="true">

  <!-- ── Navigation ─────────────────────────────────────────── -->
  <header class="site-header" role="banner">
    <nav class="site-nav container" aria-label="Main navigation">

      <a href="/" class="nav-wordmark" aria-label="Julie Johnston — home">JJ</a>

      <ul class="nav-links" role="list">
        {navItems.map(({ href, label }) => {
          const isActive = path === href || path.startsWith(href + "/");
          return (
            <li>
              <a
                href={href}
                class:list={["nav-link", { "nav-link--active": isActive }]}
                aria-current={isActive ? "page" : undefined}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Availability indicator -->
      <div class="nav-status" aria-label="Availability status">
        <span class="status-dot" aria-hidden="true"></span>
        <span class="status-label">Available for new work</span>
      </div>

    </nav>
  </header>

  <!-- ── Main content ──────────────────────────────────────── -->
  <main
    id="main-content"
    class:list={["site-main", { container: !fullBleed }]}
    tabindex="-1"
  >
    <slot />
  </main>

  <!-- ── Footer ────────────────────────────────────────────── -->
  <footer class="site-footer" role="contentinfo">
    <div class="container site-footer__inner">

      <div class="footer-left">
        <span class="nav-wordmark">JJ</span>
        <p class="footer-tagline">Designed for complexity.</p>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <ul role="list">
          {navItems.map(({ href, label }) => (
            <li><a href={href} class="footer-link">{label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="footer-contact">
        <a href="mailto:hello@juliejohnston.design" class="footer-link">
          hello@juliejohnston.design
        </a>
        <a
          href="https://linkedin.com/in/juliejohnston"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-link"
        >
          LinkedIn ↗
        </a>
      </div>

    </div>

    <div class="container footer-bottom">
      <span>© {new Date().getFullYear()} Julie Johnston</span>
      <span>Built with Astro · Deployed on Vercel</span>
    </div>
  </footer>

</div>

<style>
  /* ── Site header ─────────────────────────────────────────── */

  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: var(--bg);
    border-bottom: var(--border);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    height: 60px;
  }

  .nav-wordmark {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-wide);
    color: var(--text-1);
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    gap: var(--space-8);
    margin-right: auto;
  }

  .nav-link {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-3);
    transition: color var(--duration-fast) var(--ease-out);
    padding-block: var(--space-1);
  }

  .nav-link:hover      { color: var(--text-2); }
  .nav-link--active    { color: var(--accent); }

  .nav-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    animation: pulse 2.4s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.4; }
    }
  }

  .status-label {
    font-size: var(--text-xs);
    color: var(--text-3);
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .nav-status .status-label { display: none; }
    .nav-links { gap: var(--space-5); }
  }

  /* ── Main ────────────────────────────────────────────────── */

  .site-main {
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
    min-height: calc(100vh - 60px);
  }

  /* ── Footer ──────────────────────────────────────────────── */

  .site-footer {
    border-top: var(--border);
    padding-top: var(--space-10);
    padding-bottom: var(--space-8);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-12);
    align-items: start;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: var(--border);
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--text-3);
    margin-top: var(--space-2);
    letter-spacing: var(--tracking-tight);
    font-weight: var(--weight-medium);
  }

  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-end;
  }

  .footer-link {
    font-size: var(--text-sm);
    color: var(--text-3);
    letter-spacing: var(--tracking-wide);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .footer-link:hover { color: var(--text-1); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-xs);
    color: var(--text-4);
    letter-spacing: var(--tracking-wide);
  }

  @media (max-width: 700px) {
    .site-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
    .footer-left { grid-column: 1 / -1; }
    .footer-contact { align-items: flex-start; }
  }

  @media (max-width: 480px) {
    .site-footer__inner { grid-template-columns: 1fr; }
  }
</style>
