---
// src/layouts/EditorialLayout.astro
// Editorial layout shell: newspaper masthead, thin rule nav, colophon footer.
// Completely independent HTML structure — shares no classes with DefaultLayout.

const path = Astro.url.pathname;
const navItems = [
  { href: "/work",  label: "Work"  },
  { href: "/lab",   label: "Lab"   },
  { href: "/about", label: "About" },
];
---

<div id="shell-editorial" aria-hidden="true">

  <!-- ── Masthead ──────────────────────────────────────────── -->
  <header class="ed-header" role="banner">

    <div class="ed-masthead">
      <div class="ed-masthead__rule-top"></div>
      <div class="container ed-masthead__inner">
        <a href="/" class="ed-site-name" aria-label="Julie Johnston — home">
          Julie Johnston
        </a>
        <p class="ed-tagline">Senior UX Designer &nbsp;·&nbsp; Designing for complexity</p>
      </div>
      <div class="ed-masthead__rule-bot"></div>
    </div>

    <!-- Nav bar: thin rule row below the masthead -->
    <div class="container ed-nav-bar">
      <nav aria-label="Main navigation">
        <ul class="ed-nav" role="list">
          {navItems.map(({ href, label }) => {
            const isActive = path === href || path.startsWith(href + "/");
            return (
              <li>
                <a
                  href={href}
                  class:list={["ed-nav__link", { "ed-nav__link--active": isActive }]}
                  aria-current={isActive ? "page" : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
      <div class="ed-nav-status" aria-label="Availability status">
        <span class="ed-status-dot" aria-hidden="true"></span>
        <span>Available for new work</span>
      </div>
    </div>

  </header>

  <!-- ── Main content ──────────────────────────────────────── -->
  <main id="main-content" class="container ed-main" tabindex="-1">
    <slot />
  </main>

  <!-- ── Footer — editorial colophon ──────────────────────── -->
  <footer class="ed-footer" role="contentinfo">
    <div class="container ed-footer__inner">
      <div class="ed-colophon-left">
        <span class="ed-colophon-name">Julie Johnston</span>
        <span class="ed-colophon-tagline">Designing for complexity</span>
      </div>
      <div class="ed-colophon-right">
        <a href="mailto:hello@juliejohnston.design" class="ed-footer-link">
          hello@juliejohnston.design
        </a>
        <a
          href="https://linkedin.com/in/juliejohnston"
          target="_blank"
          rel="noopener noreferrer"
          class="ed-footer-link"
        >
          LinkedIn ↗
        </a>
      </div>
    </div>
    <div class="container ed-footer-bottom">
      <span>© {new Date().getFullYear()} Julie Johnston</span>
      <span>Built with Astro</span>
    </div>
  </footer>

</div>

<style>
  /* ── Masthead ─────────────────────────────────────────────── */

  .ed-masthead {
    padding-top: var(--space-8);
    padding-bottom: var(--space-5);
    text-align: center;
  }

  /* Double newspaper rule — thick + thin with a gap */
  .ed-masthead__rule-top {
    height: 8px;
    border-top: 4px solid var(--text-1);
    border-bottom: 1px solid var(--text-1);
    margin-bottom: var(--space-5);
  }

  .ed-masthead__rule-bot {
    height: 8px;
    border-top: 1px solid var(--text-1);
    border-bottom: 4px solid var(--text-1);
    margin-top: var(--space-5);
  }

  .ed-masthead__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  /* The headline centrepiece — this IS the brand mark */
  .ed-site-name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7.5rem);
    font-style: italic;
    font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.04em;
    line-height: 0.92;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .ed-site-name:hover { color: var(--accent); }

  .ed-tagline {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-3);
  }

  /* ── Nav bar ──────────────────────────────────────────────── */

  .ed-nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-3);
    padding-bottom: var(--space-3);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .ed-nav {
    display: flex;
    gap: var(--space-8);
  }

  .ed-nav__link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-3);
    padding-block: var(--space-1);
    border-bottom: 1px solid transparent;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .ed-nav__link:hover      { color: var(--text-1); }
  .ed-nav__link--active    {
    color: var(--text-1);
    border-bottom-color: var(--text-1);
  }

  .ed-nav-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-success);
    font-weight: 500;
  }

  .ed-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .ed-nav-status { display: none; }
    .ed-nav { gap: var(--space-5); }
  }

  /* ── Main ─────────────────────────────────────────────────── */

  .ed-main {
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
    min-height: calc(100vh - 300px);
  }

  /* ── Footer — colophon ────────────────────────────────────── */

  .ed-footer {
    border-top: 4px solid var(--text-1);
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  .ed-footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-8);
    padding-bottom: var(--space-6);
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--rule);
  }

  .ed-colophon-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .ed-colophon-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.02em;
  }

  .ed-colophon-tagline {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-3);
  }

  .ed-colophon-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: flex-end;
  }

  .ed-footer-link {
    font-size: var(--text-sm);
    color: var(--text-3);
    letter-spacing: var(--tracking-wide);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .ed-footer-link:hover { color: var(--text-1); }

  .ed-footer-bottom {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-xs);
    color: var(--text-4);
    letter-spacing: var(--tracking-wide);
  }

  @media (max-width: 600px) {
    .ed-footer__inner {
      flex-direction: column;
      gap: var(--space-6);
    }
    .ed-colophon-right { align-items: flex-start; }
  }
</style>
