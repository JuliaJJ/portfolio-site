---
// src/components/CaseStudyCard.astro

import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"work">;
}

const { entry } = Astro.props;
const { data, slug } = entry;

const leadOutcome = data.outcomes[0] ?? null;
---

<a href={`/work/${slug}`} class="cs-card" aria-label={`${data.title} — ${data.summary}`}>

  <div class="cs-card__img-wrap">
    {data.cover_image ? (
      <img
        class="cs-card__img"
        src={data.cover_image}
        alt={data.cover_alt ?? data.title}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="cs-card__placeholder" aria-hidden="true">
        <span class="cs-card__placeholder-label">{data.title}</span>
      </div>
    )}

    {data.visibility === "partial" && (
      <span class="badge badge--partial cs-card__badge">Process shown</span>
    )}
    {data.visibility === "request" && (
      <span class="badge badge--request cs-card__badge">NDA — request access</span>
    )}
  </div>

  <div class="cs-card__body">
    <div class="cs-card__left">
      <div class="cs-card__meta">
        <span class={`tag tag--${data.domain}`}>{data.domain}</span>
        <span class="cs-card__year">{data.year}</span>
      </div>
      <p class="cs-card__title">{data.title}</p>
      <p class="cs-card__summary">{data.summary}</p>
    </div>

    {leadOutcome && (
      <div class="cs-card__right">
        <p class="cs-card__val">{leadOutcome.value}</p>
        <p class="cs-card__metric">{leadOutcome.metric}</p>
      </div>
    )}
  </div>

</a>

<style>
  .cs-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* ── Image ── */

  .cs-card__img-wrap {
    position: relative;
    aspect-ratio: 3 / 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .cs-card:hover .cs-card__img-wrap {
    transform: translateY(-4px);
  }

  .cs-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Muted at rest — blooms to full colour on hover */
    filter: saturate(0.25) brightness(0.85);
    transition:
      filter     400ms var(--ease-out),
      transform  500ms var(--ease-out);
  }

  .cs-card:hover .cs-card__img {
    filter: saturate(1) brightness(1);
    transform: scale(1.02);
  }

  /* Placeholder when no cover image is set */
  .cs-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--bg-3);
    background-image:
      linear-gradient(var(--rule) 1px, transparent 1px),
      linear-gradient(90deg, var(--rule) 1px, transparent 1px);
    background-size: 40px 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
    transition: opacity 400ms var(--ease-out);
  }

  .cs-card:hover .cs-card__placeholder {
    opacity: 0.8;
  }

  .cs-card__placeholder-label {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-4);
  }

  .cs-card__badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
  }

  /* ── Body ── */

  .cs-card__body {
    padding: var(--space-4) var(--space-1) 0;
    display: grid;
    grid-template-columns: 1fr auto;
    column-gap: var(--space-6);
    align-items: start;
  }

  .cs-card__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cs-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .cs-card__year {
    font-size: var(--text-xs);
    color: var(--text-3);
  }

  .cs-card__title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: var(--weight-black);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--text-1);
    transition: color var(--duration-slow) var(--ease-out);
  }

  .cs-card:hover .cs-card__title {
    color: var(--accent);
  }

  .cs-card__summary {
    font-size: var(--text-sm);
    color: var(--text-2);
    line-height: var(--leading-relaxed);
  }

  /* ── Outcome metric ── */

  .cs-card__right {
    text-align: right;
    flex-shrink: 0;
  }

  .cs-card__val {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--text-3);
    transition: color var(--duration-slow) var(--ease-out);
  }

  .cs-card:hover .cs-card__val {
    color: var(--accent);
  }

  .cs-card__metric {
    font-size: var(--text-xs);
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-top: var(--space-1);
  }
</style>
